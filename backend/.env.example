# ===========================================
# SparkFlow Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values

# Application Settings
# --------------------
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
# --------
# IMPORTANT: Change this to a secure random string in production!
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# --------
# 默认本地开发数据库由根目录 `docker-compose.postgres.yml` 提供。
# `bash ../scripts/dev-mobile.sh` 和 `bash ../scripts/test-all.sh` 会自动确保 PostgreSQL 容器已启动。
# 如需改用远端 PostgreSQL，可直接覆盖 DATABASE_URL / TEST_DATABASE_URL。
DATABASE_URL=postgresql+psycopg://sparkflow:sparkflow@127.0.0.1:5432/sparkflow
SQLALCHEMY_ECHO=false

# Logging
# -------
LOG_LEVEL=INFO
LOG_JSON=false
MOBILE_DEBUG_LOG_PATH=./runtime_logs/mobile-debug.log

# LLM Configuration (Aliyun Tongyi Qianwen)
# -----------------------------------------
# Get your API key from: https://dashscope.console.aliyun.com/
LLM_PROVIDER=qwen
LLM_MODEL=qwen-turbo
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# External Media Configuration
# ----------------------------
# Optional: used by Douyin external media import to improve parse success rate.
# DOUYIN_COOKIE=your-douyin-web-cookie

# STT Configuration (DashScope / 阿里云百炼 - 推荐)
# --------------------------------------------------
# 仅需 DASHSCOPE_API_KEY 即可使用语音识别（与 LLM 共用同一个 Key）
# 支持模型: paraformer-v2, paraformer-realtime-v2
# 文档: https://help.aliyun.com/zh/dashscope/developer-reference/paraformer-api
STT_PROVIDER=dashscope
# 如需单独指定 STT 模型，可取消注释:
# DASHSCOPE_STT_MODEL=paraformer-v2

# Embedding Configuration
# -----------------------
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v2

# Vector Database Configuration
# -----------------------------
VECTOR_DB_PROVIDER=chromadb
CHROMADB_PATH=./chroma_data

# Storage Configuration
# ---------------------
# Relative paths are resolved from backend/ to avoid cwd-dependent drift.
FILE_STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Aliyun OSS Configuration
# ------------------------
# Used when FILE_STORAGE_PROVIDER=oss.
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=sparkflow-private
# OSS_ACCESS_KEY_ID=your-oss-access-key-id
# OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# OSS_URL_EXPIRE_SECONDS=3600
# Optional: provide a custom download domain instead of SDK-signed host.
# OSS_PUBLIC_BASE_URL=https://your-download-domain.example.com

# Dify Workflow Configuration
# ---------------------------
# Optional: used by the 统一脚本生成工作流层.
# 本地自托管 Dify 默认可配成 http://127.0.0.1:18080/v1
# 首次部署可运行：bash ../scripts/dify-local.sh start
# DIFY_BASE_URL=http://127.0.0.1:18080/v1
# DIFY_SCRIPT_APP_ID=app-uuid
# DIFY_API_KEY=app-xxx
# DIFY_SCRIPT_WORKFLOW_ID=wf-script-generation
# DIFY_POLL_INTERVAL_SECONDS=2
# DIFY_POLL_TIMEOUT_SECONDS=120
