# SparkFlow 后端环境变量配置
# 复制此文件为 .env 并填入实际值

# =============================================================================
# API 鉴权配置
# =============================================================================
SECRET_KEY=your-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# LLM 配置（阿里通义千问）
# =============================================================================
# 提供商：qwen（当前仅支持阿里云）
# 未来可扩展：wenxin, zhipu, openai, deepseek
LLM_PROVIDER=qwen

# 阿里云灵积平台 API Key
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# 模型选择：qwen-turbo（性价比高）/ qwen-max（效果最佳）/ qwen-plus（平衡）
LLM_MODEL=qwen-turbo

# =============================================================================
# STT 配置（阿里云语音识别 NLS）
# =============================================================================
# 提供商：aliyun（当前仅支持阿里云）
# 未来可扩展：xunfei, baidu
STT_PROVIDER=aliyun

# 阿里云 Access Key
# 获取地址：https://ram.console.aliyun.com/manage/ak
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# 阿里云 NLS 应用 Key
# 获取地址：https://nls-portal.console.aliyun.com/
ALIBABA_CLOUD_APP_KEY=your-nls-app-key

# =============================================================================
# Embedding 配置（阿里通义千问）
# =============================================================================
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v2

# =============================================================================
# 向量数据库配置（ChromaDB 本地）
# =============================================================================
# 提供商：chromadb（本地零配置）
# 未来可扩展：pinecone, qdrant
VECTOR_DB_PROVIDER=chromadb
CHROMADB_PATH=./chroma_data

# =============================================================================
# 数据库配置
# =============================================================================
# SQLite（MVP 阶段，零配置）
DATABASE_URL=sqlite:///./data.db

# 未来可切换为 PostgreSQL：
# DATABASE_URL=postgresql://user:password@localhost:5432/sparkflow

# =============================================================================
# 其他配置
# =============================================================================
# 后端服务地址
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 上传文件存储路径
UPLOAD_DIR=./uploads

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
