# ===========================================
# SparkFlow Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values

# Application Settings
# --------------------
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
# --------
# IMPORTANT: Change this to a secure random string in production!
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# --------
DATABASE_URL=sqlite:///./data.db

# LLM Configuration (Aliyun Tongyi Qianwen)
# -----------------------------------------
# Get your API key from: https://dashscope.console.aliyun.com/
LLM_PROVIDER=qwen
LLM_MODEL=qwen-turbo
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# External Media Configuration
# ----------------------------
# Optional: used by Douyin external media import to improve parse success rate.
# DOUYIN_COOKIE=your-douyin-web-cookie

# STT Configuration (DashScope / 阿里云百炼 - 推荐)
# --------------------------------------------------
# 仅需 DASHSCOPE_API_KEY 即可使用语音识别（与 LLM 共用同一个 Key）
# 支持模型: paraformer-v2, paraformer-realtime-v2
# 文档: https://help.aliyun.com/zh/dashscope/developer-reference/paraformer-api
STT_PROVIDER=dashscope
# 如需单独指定 STT 模型，可取消注释:
# DASHSCOPE_STT_MODEL=paraformer-v2

# Embedding Configuration
# -----------------------
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v2

# Vector Database Configuration
# -----------------------------
VECTOR_DB_PROVIDER=chromadb
CHROMADB_PATH=./chroma_data

# Storage Configuration
# ---------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
