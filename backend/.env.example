# ===========================================
# SparkFlow Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values

# Application Settings
# --------------------
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
# --------
# IMPORTANT: Change this to a secure random string in production!
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# --------
DATABASE_URL=sqlite:///./data.db

# LLM Configuration (Aliyun Tongyi Qianwen)
# -----------------------------------------
# Get your API key from: https://dashscope.console.aliyun.com/
LLM_PROVIDER=qwen
LLM_MODEL=qwen-turbo
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# STT Configuration (Aliyun NLS)
# ------------------------------
# Get your credentials from: https://nls-portal.console.aliyun.com/
STT_PROVIDER=aliyun
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_CLOUD_APP_KEY=your-nls-app-key

# Embedding Configuration
# -----------------------
EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v2

# Vector Database Configuration
# -----------------------------
VECTOR_DB_PROVIDER=chromadb
CHROMADB_PATH=./chroma_data

# Storage Configuration
# ---------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
