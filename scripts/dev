#!/bin/bash
#
# SparkFlow 统一开发脚本
# 用法: ./scripts/dev <命令> [选项]
#
# 快速开始:
#   ./scripts/dev start           # 同时启动后端和 iOS 模拟器
#   ./scripts/dev backend         # 仅启动后端
#   ./scripts/dev ios             # 仅启动 iOS 模拟器
#   ./scripts/dev build           # 构建 iOS 应用
#   ./scripts/dev doctor          # 网络诊断
#

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 项目路径
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND_DIR="$PROJECT_ROOT/backend"
MOBILE_DIR="$PROJECT_ROOT/mobile"
LOGS_DIR="$PROJECT_ROOT/logs"

# 创建日志目录
mkdir -p "$LOGS_DIR"

# 日志文件
BACKEND_LOG="$LOGS_DIR/backend.log"
MOBILE_LOG="$LOGS_DIR/mobile.log"

# 输出函数
log_info()  { echo -e "${BLUE}ℹ $1${NC}"; }
log_ok()    { echo -e "${GREEN}✓ $1${NC}"; }
log_warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
log_error() { echo -e "${RED}✗ $1${NC}"; }
log_cmd()   { echo -e "${CYAN}> $1${NC}"; }

# 获取本机 IP
get_local_ip() {
    ifconfig | grep "inet " | grep -v 127.0.0.1 | awk '{print $2}' | head -n 1
}

# 检查端口占用并清理
clean_port() {
    local port=$1
    local pid=$(lsof -ti:$port 2>/dev/null || true)
    if [ -n "$pid" ]; then
        log_warn "端口 $port 被占用，正在释放..."
        kill -9 $pid 2>/dev/null || true
        sleep 1
    fi
}

# 检查后端虚拟环境
check_venv() {
    if [ ! -d "$BACKEND_DIR/.venv" ]; then
        log_info "创建后端虚拟环境..."
        cd "$BACKEND_DIR"
        python3 -m venv .venv
        log_ok "虚拟环境创建完成"
    fi
}

# 安装后端依赖
install_backend_deps() {
    check_venv
    cd "$BACKEND_DIR"
    source .venv/bin/activate

    if [ ! -f ".venv/installed" ] || [ "requirements.txt" -nt ".venv/installed" ]; then
        log_info "安装后端依赖..."
        pip install -r requirements.txt -q \
            --trusted-host pypi.org \
            --trusted-host files.pythonhosted.org
        touch .venv/installed
        log_ok "后端依赖安装完成"
    fi
}

# 启动后端服务
cmd_backend() {
    log_info "启动后端服务..."
    clean_port 8000
    install_backend_deps

    LOCAL_IP=$(get_local_ip)
    log_info "后端地址: http://$LOCAL_IP:8000"
    log_info "API 文档: http://$LOCAL_IP:8000/docs"
    log_info "日志文件: $BACKEND_LOG"
    echo ""
    log_cmd "uvicorn main:app --reload --host 0.0.0.0 --port 8000"
    echo ""

    cd "$BACKEND_DIR"
    source .venv/bin/activate
    uvicorn main:app --reload --host 0.0.0.0 --port 8000 2>&1 | tee "$BACKEND_LOG"
}

# 启动 iOS 模拟器
cmd_ios() {
    log_info "启动 iOS 模拟器..."
    clean_port 8081

    cd "$MOBILE_DIR"
    if [ ! -d "node_modules" ]; then
        log_warn "安装前端依赖..."
        npm install
    fi

    log_info "日志文件: $MOBILE_LOG"
    echo ""
    log_cmd "npx expo start --ios"
    echo ""

    npx expo start --ios 2>&1 | tee "$MOBILE_LOG"
}

# 同时启动后端和 iOS 模拟器
cmd_start() {
    log_info "启动完整开发环境..."
    echo ""

    # 启动后端
    clean_port 8000
    clean_port 8081
    install_backend_deps

    LOCAL_IP=$(get_local_ip)
    log_ok "后端: http://$LOCAL_IP:8000"
    log_ok "前端: iOS 模拟器"
    log_info "日志: $LOGS_DIR/"
    echo ""
    log_warn "按 Ctrl+C 停止所有服务"
    echo ""

    # 后台启动后端
    cd "$BACKEND_DIR"
    source .venv/bin/activate
    uvicorn main:app --reload --host 0.0.0.0 --port 8000 > "$BACKEND_LOG" 2>&1 &
    BACKEND_PID=$!
    sleep 2

    # 检查后端是否启动成功
    if ! kill -0 $BACKEND_PID 2>/dev/null; then
        log_error "后端启动失败，请检查: $BACKEND_LOG"
        exit 1
    fi

    # 启动前端（前台）
    cd "$MOBILE_DIR"
    if [ ! -d "node_modules" ]; then
        npm install 2>&1 | tee "$MOBILE_LOG"
    fi

    # 捕获 Ctrl+C 停止后端
    trap 'kill $BACKEND_PID 2>/dev/null; exit 0' INT

    npx expo start --ios 2>&1 | tee "$MOBILE_LOG" &
    MOBILE_PID=$!

    wait $MOBILE_PID
    kill $BACKEND_PID 2>/dev/null
}

# 构建 iOS 应用
cmd_build() {
    local target="${1:-device}"

    log_info "构建 iOS 应用..."
    cd "$MOBILE_DIR"

    if [ ! -d "node_modules" ]; then
        log_warn "安装前端依赖..."
        npm install
    fi

    # 清理旧构建
    rm -rf ios/build

    if [ "$target" = "simulator" ]; then
        log_cmd "npx expo run:ios"
        npx expo run:ios
    else
        log_cmd "npx expo run:ios --device"
        npx expo run:ios --device
    fi
}

# 网络诊断
cmd_doctor() {
    echo ""
    echo -e "${GREEN}════════════════════════════════════════${NC}"
    echo -e "${GREEN}    SparkFlow 网络诊断工具${NC}"
    echo -e "${GREEN}════════════════════════════════════════${NC}"
    echo ""

    LOCAL_IP=$(get_local_ip)

    # 本机网络信息
    log_info "本机 IP: $LOCAL_IP"
    log_info "网段: $(echo $LOCAL_IP | cut -d. -f1-3).x"
    echo ""

    # 后端状态
    log_info "检查后端服务..."
    if curl -s http://localhost:8000/ > /dev/null 2>&1; then
        log_ok "后端运行正常 (localhost:8000)"

        RESPONSE=$(curl -s http://localhost:8000/api/auth/token -X POST -H "Content-Type: application/json" -d '{}' 2>/dev/null || echo "")
        if echo "$RESPONSE" | grep -q "access_token"; then
            log_ok "API 认证端点正常"
        else
            log_error "API 认证端点异常"
        fi
    else
        log_error "后端未运行"
        log_info "启动命令: ./scripts/dev backend"
    fi
    echo ""

    # 网络连通性
    log_info "检查网络连通性..."
    if curl -s http://127.0.0.1:8000/ > /dev/null 2>&1; then
        log_ok "127.0.0.1:8000 可达"
    else
        log_error "127.0.0.1:8000 不可达"
    fi

    if curl -s http://$LOCAL_IP:8000/ > /dev/null 2>&1; then
        log_ok "$LOCAL_IP:8000 可达 (手机可用)"
    else
        log_warn "$LOCAL_IP:8000 不可达"
        log_info "请确保后端使用 --host 0.0.0.0 启动"
    fi
    echo ""

    # 解决方案
    echo -e "${CYAN}提示:${NC}"
    echo "  1. 确保手机和电脑在同一 WiFi 网络"
    echo "  2. 在 App 中配置后端地址: http://$LOCAL_IP:8000"
    echo "  3. 检查防火墙设置"
}

# 查看日志
cmd_logs() {
    echo "日志文件位置:"
    echo "  后端: $BACKEND_LOG"
    echo "  前端: $MOBILE_LOG"
    echo ""

    if [ -f "$BACKEND_LOG" ]; then
        echo -e "${BLUE}=== 后端日志最后 30 行 ===${NC}"
        tail -30 "$BACKEND_LOG"
        echo ""
    fi

    if [ -f "$MOBILE_LOG" ]; then
        echo -e "${BLUE}=== 前端日志最后 30 行 ===${NC}"
        tail -30 "$MOBILE_LOG"
    fi
}

# 清理缓存
cmd_clean() {
    log_info "清理构建缓存..."

    # 后端
    find "$BACKEND_DIR" -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

    # 前端
    rm -rf "$MOBILE_DIR/ios/build"
    rm -rf "$MOBILE_DIR/.expo"
    rm -rf "$LOGS_DIR"/*.log

    log_ok "清理完成"
}

# 安装依赖
cmd_install() {
    log_info "安装后端依赖..."
    check_venv
    cd "$BACKEND_DIR"
    source .venv/bin/activate
    pip install -r requirements.txt -q \
        --trusted-host pypi.org \
        --trusted-host files.pythonhosted.org
    touch .venv/installed

    log_info "安装前端依赖..."
    cd "$MOBILE_DIR"
    npm install

    log_ok "所有依赖安装完成"
}

# 安装到真机设备
cmd_device() {
    log_info "安装到 iPhone 真机..."

    # 检查是否连接了设备
    DEVICE_COUNT=$(xcrun xctrace list devices 2>/dev/null | grep -c "iPhone\|iPad" | grep -v "Simulator" || echo "0")

    if [ "$DEVICE_COUNT" -eq "0" ]; then
        log_error "未检测到连接的 iOS 设备"
        echo ""
        echo "请按以下步骤操作："
        echo "  1. 用 USB 线连接 iPhone 到 Mac"
        echo "  2. 在 iPhone 上点击「信任此电脑」"
        echo "  3. 输入 iPhone 解锁密码"
        echo ""
        echo "已连接的设备："
        xcrun xctrace list devices 2>/dev/null | grep "iPhone\|iPad" || echo "  (无)"
        exit 1
    fi

    log_ok "检测到 $DEVICE_COUNT 个 iOS 设备"

    # 检查 Xcode 签名配置
    log_info "检查 Xcode 签名配置..."
    if [ ! -d "$MOBILE_DIR/ios" ]; then
        log_warn "未找到 iOS 项目，正在生成..."
        cd "$MOBILE_DIR"
        npx expo prebuild --platform ios
    fi

    # 确保依赖已安装
    cd "$MOBILE_DIR"
    if [ ! -d "node_modules" ]; then
        log_warn "安装前端依赖..."
        npm install
    fi

    echo ""
    log_warn "首次构建需要配置 Xcode 签名："
    log_info "1. 打开 Xcode: open ios/SparkFlowmobile.xcworkspace"
    log_info "2. 选择项目 → Signing & Capabilities"
    log_info "3. 选择你的 Personal Team（免费）"
    log_info "4. 返回终端继续"
    echo ""
    read -p "按 Enter 继续构建，或 Ctrl+C 取消..."
    echo ""

    log_info "开始构建（首次需要几分钟，请耐心等待）..."
    log_cmd "npx expo run:ios --device"
    echo ""

    npx expo run:ios --device

    echo ""
    log_ok "✅ 应用已安装到 iPhone！"
    echo ""
    log_warn "首次使用需要在手机上信任开发者证书："
    echo "   设置 → 通用 → VPN 与设备管理 → 信任你的 Apple ID"
    echo ""
    log_info "开发服务器已启动，可以开始开发！"
}

# 显示帮助
cmd_help() {
    echo ""
    echo -e "${GREEN}SparkFlow 开发脚本${NC}"
    echo ""
    echo "用法: ./scripts/dev <命令> [选项]"
    echo ""
    echo -e "${CYAN}开发命令:${NC}"
    echo "  start       同时启动后端和 iOS 模拟器（推荐）"
    echo "  backend     仅启动后端服务"
    echo "  ios         仅启动 iOS 模拟器"
    echo ""
    echo -e "${CYAN}构建命令:${NC}"
    echo "  device      安装到 iPhone 真机（USB连接）"
    echo "  build       构建 iOS 真机版本"
    echo "  build-sim   构建 iOS 模拟器版本"
    echo ""
    echo -e "${CYAN}工具命令:${NC}"
    echo "  doctor      网络诊断（排查连接问题）"
    echo "  logs        查看最新日志"
    echo "  clean       清理构建缓存"
    echo "  install     安装所有依赖"
    echo ""
    echo -e "${CYAN}示例:${NC}"
    echo "  ./scripts/dev start         # 开始开发"
    echo "  ./scripts/dev backend       # 单独启动后端"
    echo "  ./scripts/dev doctor        # 诊断网络问题"
    echo "  tail -f logs/backend.log    # 实时查看后端日志"
    echo ""
}

# 主逻辑
case "${1:-help}" in
    start|all|up)
        cmd_start
        ;;
    backend|server|api)
        cmd_backend
        ;;
    ios|mobile|simulator)
        cmd_ios
        ;;
    build)
        cmd_build device
        ;;
    build-sim|build:simulator)
        cmd_build simulator
        ;;
    device|iphone|real-device)
        cmd_device
        ;;
    doctor|diag|network)
        cmd_doctor
        ;;
    logs|log)
        cmd_logs
        ;;
    clean|clear)
        cmd_clean
        ;;
    install|deps)
        cmd_install
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        log_error "未知命令: $1"
        cmd_help
        exit 1
        ;;
esac
